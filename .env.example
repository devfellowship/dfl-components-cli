# dfl-components-cli — Environment Variables
# Copy this file to .env and adjust values as needed.

# ─── Showcase App (Vite) ────────────────────────────────────────────────

# Override the default component registry URL used by the showcase app.
# Default: https://raw.githubusercontent.com/taigfs/dfl-components-cli/main/registry
# VITE_REGISTRY_URL=

# Dev server port (default: 8080)
# VITE_PORT=8080
